# Copy to .env and adjust. Do not commit .env.

# --- Local docker-compose (Postgres in compose) ---
# DATABASE_URL is set automatically in docker-compose.yml when using the included db service.

# --- OCR (required) ---
# Run the OCR service from the smart-notebook-ocr repo (or host), then point the backend at it.
# Docker Desktop / WSL2: host machine port 9000
OCR_SERVICE_URL=http://host.docker.internal:9000
# Same-machine Linux Docker (no host.docker.internal): try http://172.17.0.1:9000
# All-in-one Docker network (legacy): http://ocr-service:9000

# --- JWT ---
JWT_SECRET=your-strong-secret-here
JWT_ALGORITHM=HS256

# --- Production / managed Postgres (docker-compose.prod.yml) ---
# DATABASE_URL=postgresql://user:password@host:5432/dbname
